```{r}
# =========================================================
# 3. SAFE LOADER
# =========================================================

safe_read <- function(path) {
  tryCatch(
    vroom(path, show_col_types = FALSE, progress = FALSE),
    error = function(e) {
      cat("FAILED FILE:", path, "\n")
      NULL
    }
  )
}

```

```{r}
# =========================================================
# 4. INGESTION + AGGREGATION
# =========================================================

cat("\n[STEP 3] Processing state folders...\n")

all_states <- list()

for (folder in state_folders) {

  state_name <- basename(folder)
  cat("\nProcessing:", state_name, "\n")

  incident <- safe_read(file.path(folder, "NIBRS_incident.csv"))
  offense <- safe_read(file.path(folder, "NIBRS_OFFENSE.csv"))
  offense_type <- safe_read(file.path(folder, "NIBRS_OFFENSE_TYPE.csv"))
  agencies <- safe_read(file.path(folder, "agencies.csv"))

  if (any(is.null(list(incident, offense, offense_type, agencies)))) {
    cat("SKIPPED:", state_name, "\n")
    next
  }

  incident <- incident %>% filter(data_year == 2024)
  offense <- offense %>% filter(data_year == 2024)

  crime <- offense %>%
    left_join(offense_type, by = "offense_code") %>%
    mutate(
      offense_group_lower = str_to_lower(offense_group),
      offense_category_lower = str_to_lower(offense_category_name),

      crime_category = case_when(
        offense_group_lower %in% violent_codes |
          offense_category_lower %in% violent_codes ~ "violent",

        offense_group_lower %in% property_codes |
          offense_category_lower %in% property_codes ~ "property",

        TRUE ~ "other"
      )
    ) %>%
    left_join(incident %>% select(incident_id, agency_id), by = "incident_id") %>%
    left_join(
      agencies %>% select(agency_id, county_name, state_name, region_desc),
      by = "agency_id"
    )

  county_summary <- crime %>%
    group_by(state_name, county_name, region_desc) %>%
    summarise(
      violent_count = sum(crime_category == "violent", na.rm = TRUE),
      property_count = sum(crime_category == "property", na.rm = TRUE),
      .groups = "drop"
    ) %>%
    rename(
      state = state_name,
      county = county_name,
      region = region_desc
    )

  cat("  Counties:", nrow(county_summary),
      "| Violent:", sum(county_summary$violent_count),
      "| Property:", sum(county_summary$property_count), "\n")

  all_states[[state_name]] <- county_summary
}

cat("\n[STEP 3 COMPLETE]\n")

```

